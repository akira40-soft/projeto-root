# ═══════════════════════════════════════════════════════════════════════════
# AKIRA BOT V21 - CONFIGURAÇÃO DO AMBIENTE
# ═══════════════════════════════════════════════════════════════════════════
# Arquivo .env para configurações locais
# Valores padrão do ConfigManager estão definidos como fallback
# Preencha apenas as chaves de API que você possui
# ═══════════════════════════════════════════════════════════════════════════

# ═══ PORTAS E URLs ═══
PORT=3000
API_URL=https://akra35567-akira.hf.space/api/akira
API_TIMEOUT=120000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=1000
BASE_URL=https://index-js21-production.up.railway.app

# ═══ BOT IDENTITY ═══
BOT_NUMERO=3783926588639
BOT_NAME=akira
PREFIXO=*

# ═══ FOLDERS (não precisam ser alterados) ═══
TEMP_FOLDER=/tmp/akira_data/temp
AUTH_FOLDER=/tmp/akira_data/auth_info_baileys
DATABASE_FOLDER=/tmp/akira_data/database
LOGS_FOLDER=/tmp/akira_data/logs

# ═══ STT - SPEECH TO TEXT (Deepgram) ═══
# Obtenha sua chave em: https://console.deepgram.com
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
STT_LANGUAGE=pt

# ═══ TTS - TEXT TO SPEECH ═══
TTS_LANGUAGE=pt
TTS_SLOW=false

# ═══ RATE LIMITING ═══
RATE_LIMIT_WINDOW=8
RATE_LIMIT_MAX_CALLS=6

# ═══ MODERAÇÃO ═══
MUTE_DEFAULT_MINUTES=5
MUTE_MAX_DAILY=5
AUTO_BAN_AFTER_MUTES=3

# ═══ YOUTUBE DOWNLOAD ═══
YT_MAX_SIZE_MB=2048
YT_TIMEOUT_MS=3600000
YT_QUALITY=highestaudio
YT_MAX_DURATION_SECONDS=21600

# YouTube Bypass - COOKIES (obrigatório para alguns vídeos)
# Método 1: Caminho para ficheiro de cookies
YT_COOKIES_PATH=
# Método 2: cookies em base64 (para Railway)
YT_COOKIES_BASE64=
# Método 3: PO Token (obrigatório para alguns vídeos)
YT_PO_TOKEN=

# ═══ MÍDIA ═══
STICKER_SIZE=512
STICKER_MAX_ANIMATED_SECONDS=30
IMAGE_QUALITY=85
MAX_AUDIO_SIZE_MB=500

# ═══ CONVERSAÇÃO ═══
MAX_RESPONSE_CHARS=280
TYPING_SPEED_MS=50
MIN_TYPING_TIME_MS=1500
MAX_TYPING_TIME_MS=30000

# ═══ CACHE E PERFORMANCE ═══
CACHE_TTL_SECONDS=3600
HISTORY_LIMIT_PER_USER=50
MESSAGE_DEDUP_TIME_MS=30000

# ═══ LOGGING ═══
LOG_LEVEL=info
LOG_API_REQUESTS=true
LOG_DETAILED_MESSAGES=true

# ═══ FEATURES (true/false) ═══
FEATURE_STT=true
FEATURE_TTS=true
FEATURE_YT=true
FEATURE_STICKERS=true
FEATURE_MODERATION=true
FEATURE_LEVELING=true
FEATURE_VISION=true

# ═══ OSINT/APIs EXTERNAS ═══
# HaveIBeenPwned - https://haveibeenpwned.com/API/v3
HIBP_API_KEY=
# Numverify - https://numverify.com/documentation
NUMVERIFY_API_KEY=
# GitHub Token (para busca de usernames)
GITHUB_TOKEN=

# ═══ HUGGING FACE (não altere) ═══
HF_SPACE=true
NODE_ENV=production
HF_PORT=3000
HF_API_URL=https://akra35567-akira.hf.space/api/akira
